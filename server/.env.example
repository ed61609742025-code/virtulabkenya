# VirtuLab Kenya — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file to GitHub

# Server
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/virtulabkenya

# Authentication
JWT_SECRET=replace_this_with_a_long_random_string_at_least_32_characters
JWT_EXPIRES_IN=7d

# Environment
NODE_ENV=development
